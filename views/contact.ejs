<%- include('partials/header') %>

<main class="modern-page">
    <!-- Hero Section -->
    <section class="inner-hero">
        <h1>Let's Talk Sparkle</h1>
        <p>Whether you have a question about our services or want to book a specialized clean, our team is ready to help you shine.</p>
    </section>

    <div class="modern-content">
        <div class="contact-wrapper">
            <!-- Contact Info Section -->
            <div class="contact-info-section">
                <h2>Get in Touch</h2>
                <p style="color: #666; margin-bottom: 3rem;">We are here to assist you with all your cleaning needs in Kisumu and beyond.</p>
                
                <div class="contact-method-list">
                    <!-- Phone -->
                    <div class="contact-method-item">
                        <a href="tel:+254745728079" class="contact-link">
                            <div class="contact-icon-box">
                                <i class="fas fa-phone"></i>
                            </div>
                            <div class="contact-detail-text">
                                <h4>Call Us</h4>
                                <p>+254 7 457 280 79</p>
                            </div>
                        </a>
                    </div>

                    <!-- Email -->
                    <div class="contact-method-item">
                        <a href="mailto:tidyhands.africa@gmail.com" class="contact-link">
                            <div class="contact-icon-box">
                                <i class="fas fa-envelope"></i>
                            </div>
                            <div class="contact-detail-text">
                                <h4>Email Us</h4>
                                <p>tidyhands.africa@gmail.com</p>
                            </div>
                        </a>
                    </div>

                    <!-- Address -->
                    <div class="contact-method-item">
                        <a href="https://maps.google.com/?q=-0.10221, 34.76171" target="_blank" class="contact-link">
                            <div class="contact-icon-box">
                                <i class="fas fa-map-marker-alt"></i>
                            </div>
                            <div class="contact-detail-text">
                                <h4>Visit Us</h4>
                                <p>40100-7528, Kisumu</p>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Contact Form Section -->
            <div class="contact-form-section">
                <form action="/contact" method="POST">
                    <div class="field">
                        <label for="name">Your Name</label>
                        <input type="text" id="name" name="name" placeholder="John Doe" required>
                    </div>

                    <div class="input-row">
                        <div class="field">
                            <label for="email">Email Address</label>
                            <input type="email" id="email" name="email" placeholder="john@example.com" required>
                        </div>
                        <div class="field">
                            <label for="phone">Phone Number</label>
                            <input type="tel" id="phone" name="phone" placeholder="+254 7XX XXX XXX" required>
                        </div>
                    </div>

                    <div class="field">
                        <label for="message">Your Message</label>
                        <textarea id="message" name="message" placeholder="How can we help you today?" required></textarea>
                    </div>

                    <div style="margin-top: 2rem;">
                        <button type="submit" class="btn" style="width: 100%; padding: 1rem;">Send Message</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
