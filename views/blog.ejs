<%- include('partials/header') %>

<main class="modern-page">
    <!-- Hero Section -->
    <section class="inner-hero">
        <h1>TidyHands Blog</h1>
        <p>Expert tips, maintenance tricks, and professional secrets to keeping your environment sparkling every day.</p>
    </section>

    <div class="modern-content">
        <% if (blogs && blogs.length > 0) { %>
            <div class="blog-grid">
                <% blogs.forEach(blog => { %>
                    <article class="blog-card">
                        <div class="blog-image" style="background-image: url('<%= blog.media ? process.env.DIRECTUS_URL + "/assets/" + blog.media.id : "/images/placeholder.jpg" %>');">
                            <% if (blog.badge) { %>
                                <span class="blog-category"><%= blog.badge %></span>
                            <% } %>
                        </div>
                        <div class="blog-content">
                            <span class="blog-date"><%= new Date(blog.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
                            <h2><%= blog.title %></h2>
                            <!-- Strip HTML for excerpt -->
                            <p><%= blog.body.replace(/<[^>]*>?/gm, '').substring(0, 150) %>...</p>
                            <a href="/blog/<%= blog.id %>" class="read-more-btn">Read More <i class="fas fa-arrow-right"></i></a>
                        </div>
                    </article>
                <% }); %>
            </div>
        <% } else { %>
            <div style="text-align: center; padding: 5rem 0;">
                <i class="fas fa-feather" style="font-size: 3rem; color: #eee; margin-bottom: 2rem; display: block;"></i>
                <h2>No articles yet.</h2>
                <p>We are currently writing some sparkling content for you. Check back soon!</p>
            </div>
        <% } %>
    </div>
</main>

<%- include('partials/header') %>
