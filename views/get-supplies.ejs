<%- include('partials/header') %>

<main class="modern-page">
    <!-- Hero Section -->
    <section class="inner-hero">
        <h1>Let us Handle Your Supply Needs</h1>
        <p>From cleaning products to office furniture, hospital equipment to school supplies — we deliver quality products to your doorstep.</p>
    </section>

    <div class="modern-content">
        <form action="/submit-supplies" method="POST">
            <!-- Step 1: Contact Details -->
            <div class="form-group">
                <h3>1. Contact Information</h3>
                <div class="input-row">
                    <div class="field">
                        <label for="name">Full Name</label>
                        <input type="text" id="name" name="name" placeholder="John Doe" required>
                    </div>
                    <div class="field">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" name="email" placeholder="john@example.com" required>
                    </div>
                </div>
                <div class="input-row">
                    <div class="field">
                        <label for="phone">Phone Number</label>
                        <input type="tel" id="phone" name="phone" placeholder="+254 7XX XXX XXX" required>
                    </div>
                    <div class="field">
                        <label for="location">Delivery Address</label>
                        <input type="text" id="location" name="location" placeholder="e.g., Milimani, Kisumu" required>
                    </div>
                </div>
            </div>

            <!-- Step 2: Supply Category -->
            <div class="form-group">
                <h3>2. Supply Category</h3>
                <div class="selection-grid">
                    <label class="selection-card">
                        <input type="radio" name="supply_category" value="cleaning-products" checked>
                        <div class="card-content">Cleaning Products</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="supply_category" value="office-supplies">
                        <div class="card-content">Office Supplies</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="supply_category" value="hospital-medical">
                        <div class="card-content">Hospital & Medical</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="supply_category" value="school-educational">
                        <div class="card-content">School & Educational</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="supply_category" value="furniture">
                        <div class="card-content">Furniture</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="supply_category" value="general">
                        <div class="card-content">General Supplies</div>
                    </label>
                </div>
            </div>

            <!-- Step 3: Dynamic Category Details -->
