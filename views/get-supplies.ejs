</main>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const categoryRadios = document.querySelectorAll('input[name="supply_category"]');
        const categoryDetails = document.querySelectorAll('.category-details');

        function showCategoryDetails(categoryValue) {
            categoryDetails.forEach(detail => {
                if (detail.id === 'category-' + categoryValue) {
                    detail.classList.remove('hidden');
                    detail.style.display = 'block';
                } else {
                    detail.classList.add('hidden');
                    detail.style.display = 'none';
                }
            });
        }

        categoryRadios.forEach(radio => {
            radio.addEventListener('change', function() {
                showCategoryDetails(this.value);
            });
        });

        const selectedCategory = document.querySelector('input[name="supply_category"]:checked');
        if (selectedCategory) {
            showCategoryDetails(selectedCategory.value);
        }
    });
</script>

