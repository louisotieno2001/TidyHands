<%- include('partials/header') %>

<main class="modern-page">
    <!-- Hero Section -->
    <section class="inner-hero">
        <h1>Our Cleaning Services</h1>
        <p>Providing top-tier, professional cleaning solutions tailored for your home and business. Your space, our passion.</p>
    </section>

    <div class="modern-content">
        <div class="services-section">
            
            <!-- Recurring Cleaning -->
            <div class="service-row" id="recurring">
                <div class="service-image" style="background-image: url('/images/recurring-cleaning.jpg');"></div>
                <div class="service-text">
                    <h2>Recurring Cleaning</h2>
                    <p>Keep your home or office consistently pristine with our flexible recurring cleaning services. Whether you need us weekly, bi-weekly, or monthly, we ensure a seamless and reliable experience.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check-circle"></i> Flexible Scheduling</li>
                        <li><i class="fas fa-check-circle"></i> Consistent Team</li>
                        <li><i class="fas fa-check-circle"></i> Surface Sanitization</li>
                        <li><i class="fas fa-check-circle"></i> Custom Checklists</li>
                    </ul>
                    <a href="/get-quotation" class="btn" style="margin-top: 2rem;">Book Now</a>
                </div>
            </div>

            <!-- Deep Cleaning -->
            <div class="service-row" id="deep">
                <div class="service-image" style="background-image: url('/images/deep-clean.jpg');"></div>
                <div class="service-text">
                    <h2>Deep Cleaning</h2>
                    <p>For those times when a standard clean isn't enough. Our deep cleaning service targets hidden allergens, accumulated dust, and tough grime in every corner of your environment.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check-circle"></i> Wall Washing</li>
                        <li><i class="fas fa-check-circle"></i> Inside Appliances</li>
                        <li><i class="fas fa-check-circle"></i> Detailed Scrubbing</li>
                        <li><i class="fas fa-check-circle"></i> Specialized Equipment</li>
                    </ul>
                    <a href="/get-quotation" class="btn" style="margin-top: 2rem;">Get Started</a>
                </div>
            </div>

            <!-- Move In / Out Cleaning -->
            <div class="service-row" id="move">
                <div class="service-image" style="background-image: url('/images/move-clean.jpg');"></div>
                <div class="service-text">
                    <h2>Move In / Out Cleaning</h2>
                    <p>Relocating is stressful—cleaning shouldn't be. We ensure your new home is perfectly sanitized before you arrive, or your old space is pristine for the next occupants.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check-circle"></i> Full Sanitization</li>
                        <li><i class="fas fa-check-circle"></i> Cabinet Detailing</li>
                        <li><i class="fas fa-check-circle"></i> Floor Restoration</li>
                        <li><i class="fas fa-check-circle"></i> Stress-Free Guarantee</li>
                    </ul>
                    <a href="/get-quotation" class="btn" style="margin-top: 2rem;">Plan Your Move</a>
                </div>
            </div>

            <!-- Commercial Cleaning -->
            <div class="service-row" id="commercial">
                <div class="service-image" style="background-image: url('/images/commercial-clean.jpg');"></div>
                <div class="service-text">
                    <h2>Commercial Cleaning</h2>
                    <p>A clean office is a productive office. We provide world-class commercial cleaning services for businesses of all sizes, from boutiques to large corporate complexes.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check-circle"></i> Tech Sanitization</li>
                        <li><i class="fas fa-check-circle"></i> High-Traffic Areas</li>
                        <li><i class="fas fa-check-circle"></i> After-Hours Support</li>
                        <li><i class="fas fa-check-circle"></i> Professional Image</li>
                    </ul>
                    <a href="/get-quotation" class="btn" style="margin-top: 2rem;">Business Inquiries</a>
                </div>
            </div>

            <!-- General Supplies & Cleaning Supplies -->
            <div class="service-row" id="supplies">
                <div class="service-image" style="background-image: url('/images/supplies.jpg');"></div>
                <div class="service-text">
                    <h2>General Supplies & Cleaning Supplies</h2>
                    <p>We provide premium cleaning products and general supplies to keep your home or business sparkling. From eco-friendly detergents to professional-grade equipment, we have everything you need.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check-circle"></i> Eco-Friendly Products</li>
                        <li><i class="fas fa-check-circle"></i> Professional Equipment</li>
                        <li><i class="fas fa-check-circle"></i> Bulk Orders Available</li>
                        <li><i class="fas fa-check-circle"></i> Home & Office Supplies</li>
                    </ul>
                    <a href="/get-quotation" class="btn" style="margin-top: 2rem;">Order Supplies</a>
                </div>
            </div>

        </div>
    </div>
</main>

<%- include('partials/footer') %>
