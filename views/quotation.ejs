<%- include('partials/header') %>

<main class="modern-page">
    <!-- Hero Section -->
    <section class="inner-hero">
        <h1>Get a Quotation</h1>
        <p>Your journey to a sparkling space begins here. Provide your details below for a personalized world-class cleaning plan.</p>
    </section>

    <div class="modern-content">
        <form action="/submit-quotation" method="POST">
            <!-- Step 1: Contact Details -->
            <div class="form-group">
                <h3>1. Contact Information</h3>
                <div class="input-row">
                    <div class="field">
                        <label for="name">Full Name</label>
                        <input type="text" id="name" name="name" placeholder="John Doe" required>
                    </div>
                    <div class="field">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" name="email" placeholder="john@example.com" required>
                    </div>
                </div>
                <div class="input-row">
                    <div class="field">
                        <label for="phone">Phone Number</label>
                        <input type="tel" id="phone" name="phone" placeholder="+254 7XX XXX XXX" required>
                    </div>
                    <div class="field">
                        <label for="location">Location (Physical Address)</label>
                        <input type="text" id="location" name="location" placeholder="e.g., Milimani, Kisumu" required>
                    </div>
                </div>
            </div>

            <!-- Step 2: Service Category -->
            <div class="form-group">
                <h3>2. Service Category</h3>
                <div class="selection-grid">
                    <label class="selection-card">
                        <input type="radio" name="service_category" value="residential" checked>
                        <div class="card-content">Residential</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_category" value="commercial">
                        <div class="card-content">Commercial</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_category" value="move-in-out">
                        <div class="card-content">Move In/Out</div>
                    </label>
                </div>
            </div>

            <!-- Step 3: Cleaning Level -->
            <div class="form-group">
                <h3>3. Cleaning Level</h3>
                <div class="simple-selection-grid">
                    <label class="simple-card">
                        <input type="radio" name="cleaning_level" value="standard" checked>
                        <div class="simple-card-content">Standard Cleaning</div>
                    </label>
                    <label class="simple-card">
                        <input type="radio" name="cleaning_level" value="deep">
                        <div class="simple-card-content">Deep Cleaning</div>
                    </label>
                </div>
            </div>

            <!-- Step 4: Cleaning Frequency -->
            <div class="form-group">
                <h3>4. Cleaning Frequency</h3>
                <div class="selection-grid">
                    <label class="selection-card">
                        <input type="radio" name="frequency" value="one-time" checked>
                        <div class="card-content">One Time</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="frequency" value="weekly">
                        <div class="card-content">Weekly</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="frequency" value="bi-weekly">
                        <div class="card-content">Bi-Weekly</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="frequency" value="monthly">
                        <div class="card-content">Monthly</div>
                    </label>
                </div>
            </div>

            <!-- Step 5: Special Instructions -->
            <div class="form-group" style="margin-top: 4rem;">
                <h3>5. Special Instructions</h3>
                <textarea id="message" name="message" placeholder="Provide any specific details or special requests here..."></textarea>
            </div>

            <div style="text-align: center; margin-top: 5rem;">
                <button type="submit" class="btn" style="padding: 1rem 4rem; font-size: 1.1rem; border-radius: 50px;">Submit Quote Request</button>
            </div>
        </form>
    </div>
</main>

<%- include('partials/footer') %>
